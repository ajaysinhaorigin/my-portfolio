{
  "files.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/node_modules": true,
    "**/.yarn-cache": true,
    "**/.npm-cache": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.yarn-cache": true,
    "**/.npm-cache": true,
    "yarn.lock": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.yarn-cache/**": true,
    "**/.npm-cache/**": true
  }
}
